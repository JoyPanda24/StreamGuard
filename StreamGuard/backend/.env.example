# StreamGuard Environment Configuration
# Copy this file to .env and update values as needed

# Deployment environment (set to 'production' on Render, leave empty for local development)
RENDER=

# Flask settings
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_PORT=5000

# API settings
CORS_ORIGINS=*

# Database settings
# Leave empty to use default location (~/StreamGuardDB on Windows, ~/.streamguard on Linux)
# DB_PATH=/custom/path/to/streamguard.db

# Optional: GeoIP API settings (if using custom provider)
# GEOIP_API_KEY=
